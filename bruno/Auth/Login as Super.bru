meta {
  name: Login as Super
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "super@emg.com",
    "password": "ChangeMe123!"
  }
}

script:post-response {
  if (res.body && res.body.accessToken) {
    bru.setEnvVar("accessToken", res.body.accessToken);
  }
}
