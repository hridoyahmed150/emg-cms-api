meta {
  name: Invite User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "email": "boss@acme.com",
    "name": "Acme Boss",
    "role": "ADMIN",
    "organizationId": {{orgId}}
  }
}

script:post-response {
  if (res.body && res.body.id) {
    bru.setEnvVar("userId", res.body.id);
  }
}
