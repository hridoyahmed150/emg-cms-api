# ─── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Comma-separated list of allowed admin/web origins
CORS_ORIGIN=http://localhost:3000

# ─── Database (Postgres) ───────────────────────────────────────────────
# Local Homebrew/docker Postgres (port 5433 to avoid clashing with any existing PG on 5432):
#   postgresql://emg:dev_password@localhost:5433/emg_cms
# Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://emg:dev_password@localhost:5433/emg_cms

# ─── Auth (JWT) ────────────────────────────────────────────────────────
# Generate strong secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Encryption (AES-256-GCM for stored per-org secrets) ───────────────
# 32-byte key as 64 hex chars, e.g. `openssl rand -hex 32`
ENCRYPTION_KEY=

# ─── Cloudflare R2 (S3-compatible) — needed for uploads ────────────────
R2_ACCOUNT_ID=a439dc1c81de14d9ac3955088ca4a725
# R2 API token (Object Read & Write) — create in Cloudflare → R2 → Manage API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=emgcms
# Public base URL for served files — enable the bucket's Public Dev URL (https://pub-XXXX.r2.dev)
# or connect a custom domain (e.g. https://cdn.emg.com)
R2_PUBLIC_BASE=
R2_ENDPOINT=https://a439dc1c81de14d9ac3955088ca4a725.r2.cloudflarestorage.com

# ─── Google reviews ingestion (optional — only to auto-refresh from Google) ──
# Places API (New) key — for source='places'
GOOGLE_MAPS_API_KEY=
# Business Profile (GBP) OAuth client — for source='gbp'
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Error tracking (optional) ─────────────────────────────────────────
SENTRY_DSN=
