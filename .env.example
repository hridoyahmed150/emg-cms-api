# ─── Core ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Comma-separated list of allowed admin/web origins
CORS_ORIGIN=http://localhost:3000

# ─── Database (Postgres) ───────────────────────────────────────────────
# Local docker-compose: postgresql://emg:dev_password@localhost:5432/emg_cms
# Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://emg:dev_password@localhost:5432/emg_cms

# ─── Auth (JWT) ────────────────────────────────────────────────────────
# Generate strong secrets, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Encryption (AES-256-GCM for stored per-org secrets) ───────────────
# 32-byte key as 64 hex chars, e.g. `openssl rand -hex 32`
ENCRYPTION_KEY=

# ─── Cloudflare R2 (S3-compatible) — needed for uploads ────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=emg-cms-files
# Public base URL for served files (e.g. https://cdn.emg.com)
R2_PUBLIC_BASE=
# Optional explicit S3 endpoint (defaults to https://<account>.r2.cloudflarestorage.com)
R2_ENDPOINT=

# ─── Error tracking (optional) ─────────────────────────────────────────
SENTRY_DSN=
